@{
    ViewData["Title"] = "Job Details & Scheduling";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: ltr; }

body {
            font-family: 'Inter', 'Noto Sans Arabic', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
</style>

<div dir="ltr">
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 lg:px-40 py-3">
<div class="flex items-center gap-4 text-primary">
<div class="size-8 flex items-center justify-center bg-primary/10 rounded-lg">
<span class="material-symbols-outlined text-primary">home_repair_service</span>
</div>
<h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight tracking-[-0.015em]">Salahly</h2>
</div>
<div class="flex flex-1 justify-end gap-4">
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
<span class="material-symbols-outlined">notifications</span>
</button>
<div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border border-slate-200 dark:border-slate-700" data-alt="User profile picture" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuC3Y0nIEVhsw4sEV2Tb6Jzd_sjM_-ce5Pr5xdAddo5wMJ0TzpU3VFhDG1k0rl-Ax37t2GbrkylDA2JQhB_z5Zo-KI6D-WGXqdVm4VeQq00e5SKyEDZoi8MD3SwCi0-EjQVhVZDulrZ2-zcFj3oZECzqDUsRBiAjYRpUmVju_f7WoR1WtTSBQDlziboCappr0eVR07D6isaKJZmhi2-NML5TE71rFLEseiqBVF7FXcTlybwvWczdigHFZJU4xOF8WX6cmLApwyq7f24");'></div>
</div>
</header>
<main class="flex flex-1 justify-center py-8">
<div class="layout-content-container flex flex-col w-full max-w-[960px] px-6">
<!-- Progress Indicator -->
<div class="flex flex-col gap-3 mb-8">
<div class="flex gap-6 justify-between items-center">
<p class="text-slate-900 dark:text-slate-100 text-base font-bold">Step 2 of 4</p>
<p class="text-primary text-sm font-bold">50% Complete</p>
</div>
<div class="h-2.5 w-full rounded-full bg-slate-200 dark:bg-slate-800">
<div class="h-2.5 rounded-full bg-primary" style="width: 50%;"></div>
</div>
<p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Job Details &amp; Scheduling</p>
</div>
<div class="mb-8">
<h1 class="text-slate-900 dark:text-white text-3xl font-extrabold leading-tight">Job Details &amp; Scheduling</h1>
<p class="text-slate-500 dark:text-slate-400 mt-2">Please provide accurate details to help us select the right technician for you.</p>
</div>
<!-- Form Sections -->
<div class="space-y-8">
<!-- Problem Description -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
<label class="flex flex-col gap-4">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-primary">edit_note</span>
<span class="text-slate-900 dark:text-white text-lg font-bold">Problem Description</span>
</div>
<textarea class="form-textarea w-full rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary min-h-[140px] p-4 text-base placeholder:text-slate-400" placeholder="Please describe the issue you are facing in detail..."></textarea>
</label>
</section>
<!-- Photo Upload -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-primary">add_a_photo</span>
<span class="text-slate-900 dark:text-white text-lg font-bold">Upload Photos (Optional)</span>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
<button class="aspect-square flex flex-col items-center justify-center border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-lg hover:border-primary hover:bg-primary/5 transition-colors">
<span class="material-symbols-outlined text-slate-400 mb-2">add</span>
<span class="text-xs text-slate-500">Add Photo</span>
</button>
<!-- Placeholder for uploaded photo -->
<div class="aspect-square bg-slate-100 dark:bg-slate-800 rounded-lg relative overflow-hidden group">
<div class="absolute inset-0 bg-primary/20 hidden group-hover:flex items-center justify-center cursor-pointer">
<span class="material-symbols-outlined text-white">delete</span>
</div>
<div class="w-full h-full bg-cover bg-center" data-alt="A close up photo of a broken kitchen faucet" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuB36Hht_W-JjAhfIc5btl8MUpTrZPlFvrqeqjMurqANcVg35P8CO0U009WoF6agnXs45C1G7uCOXHDK0We4TJJp5TaUsPeghDM09FWhHEeF8L1sPgJDm8SVsdMZYb9yPuOVwtq0oogp16iTAHTSx2DbDE_V9kn_5JcUQk7g1RcEZ2VKutpqvv8oNk_AKA2ONHBWjixK5VSiPbSYYf3trQv0FHUFxGOim-uN6GV19BjHZgnB0ACrvD9UEwJvM1A1zk3AwDNVl76XYGA')"></div>
</div>
</div>
</section>
<!-- Scheduling -->
<section class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800">
<div class="flex items-center gap-2 mb-6">
<span class="material-symbols-outlined text-primary">calendar_month</span>
<span class="text-slate-900 dark:text-white text-lg font-bold">Select Date/Time</span>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300">Date</label>
<div class="relative">
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">event</span>
<input class="form-input w-full pl-4 pr-10 rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary" type="date"/>
</div>
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-bold text-slate-700 dark:text-slate-300">Time</label>
<div class="relative">
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">schedule</span>
<select class="form-select w-full pl-4 pr-10 rounded-lg border-slate-300 dark:border-slate-700 bg-transparent focus:ring-primary focus:border-primary">
<option>Morning (8 AM - 12 PM)</option>
<option>Afternoon (12 PM - 4 PM)</option>
<option>Evening (4 PM - 8 PM)</option>
</select>
</div>
</div>
</div>
</section>
</div>
<!-- Footer Navigation Buttons -->
<div class="mt-12 flex items-center justify-between gap-4">
<button class="px-8 py-3 rounded-lg font-bold text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                            Back
                        </button>
<button class="px-10 py-3 rounded-lg font-bold bg-primary text-white hover:bg-primary/90 shadow-lg shadow-primary/20 transition-all flex items-center gap-2">
<span>Continue</span>
<span class="material-symbols-outlined text-sm">arrow_forward</span>
</button>
</div>
</div>
</main>
<!-- Mobile Bottom Nav Placeholder -->
<footer class="md:hidden border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4 flex justify-around">
<div class="flex flex-col items-center text-primary">
<span class="material-symbols-outlined">home</span>
<span class="text-[10px]">Home</span>
</div>
<div class="flex flex-col items-center text-slate-400">
<span class="material-symbols-outlined">history</span>
<span class="text-[10px]">My Requests</span>
</div>
<div class="flex flex-col items-center text-slate-400">
<span class="material-symbols-outlined">person</span>
<span class="text-[10px]">Account</span>
</div>
</footer>
</div>
</div>
</div>
