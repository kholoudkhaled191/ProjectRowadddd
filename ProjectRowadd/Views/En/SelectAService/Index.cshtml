<div class="w-full h-40 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden mb-4 bg-center bg-cover" data-alt="Plumber fixing a pipe under a sink" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAU27VMoed-couSXjSZCarzNgc9FVVXfGt6eHUvQn90fYkpXDCKdRms3rh3djjudsAWYl_XlkmydQfk79L1NPOQchdLSy3QaiqWPxtXG364YUHS-wrTrcbf6cIL8o8uB9o8a89u2ZCK2qEgF1GUh7kLIctt37fqila9QYtnDrVx0kMa0JqFU-TTOfY6QcPwhn_wu5gviJ8W5qv-HT8QpXFgSl7EoaqzMT4f-785-ZwVS2wFhsG7ZOvZOucwOaC63fGztI2QOdtnSA0');"></div>
