@{
    ViewData["Title"] = "Select a Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: ltr; }

.material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
</style>

<div dir="ltr">
<div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 md:px-20 py-4 sticky top-0 z-50">
<div class="flex items-center gap-8">
<div class="flex items-center gap-2 text-primary">
<span class="material-symbols-outlined text-3xl">home_repair_service</span>
<h2 class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-tight">Solhly</h2>
</div>
<nav class="hidden md:flex items-center gap-6">
<a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="#">Home</a>
<a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="#">My Requests</a>
<a class="text-slate-600 dark:text-slate-300 text-sm font-medium hover:text-primary transition-colors" href="#">Profile</a>
</nav>
</div>
<div class="flex flex-1 justify-end gap-4 items-center">
<label class="hidden sm:flex flex-col min-w-40 h-10 max-w-64">
<div class="flex w-full flex-1 items-stretch rounded-lg h-full bg-slate-100 dark:bg-slate-800">
<div class="text-slate-500 flex items-center justify-center pl-3">
<span class="material-symbols-outlined text-xl">search</span>
</div>
<input class="w-full border-none bg-transparent focus:ring-0 text-sm placeholder:text-slate-500 px-2" placeholder="Search for services..." value=""/>
</div>
</label>
<div class="bg-primary/10 p-1 rounded-full border border-primary/20">
<div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-8" data-alt="User profile picture of a smiling man" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDUKwOWRtx_5Ektv7eXnbnzqTSJfpU_KIljoxVUL_IANtdzY_qEAdaXFHdangbVeQQoA3KTVl0lg7UpX6Ee7LclLH6qJ-WphWE0sbS3RLSeiT0hF974iZxFH62bNxkJ4K1RlM9ky8COKKUjqdP1_KZJ9JvvwZ1tV9-D5E3-3hAO7uUvDzzNI5N9zJ_5sMDlg1j23FjeuZ0rhi87MtJHDAyIUeg-cvVZIRODpdFUVx8znmJS6aEOQR78NziIz__d_3wViDAi4iIqSe8");'></div>
</div>
</div>
</header>
<main class="flex-1 flex flex-col max-w-5xl mx-auto w-full px-6 py-8">
<!-- Sidebar/Profile Summary and Progress -->
<div class="flex flex-col lg:flex-row gap-8">
<aside class="w-full lg:w-64 flex flex-col gap-6 order-last lg:order-first">
<div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
<div class="flex items-center gap-3 mb-6">
<div class="bg-primary/10 p-2 rounded-lg text-primary">
<span class="material-symbols-outlined">waving_hand</span>
</div>
<div class="flex flex-col">
<h1 class="text-slate-900 dark:text-white text-sm font-semibold">Welcome back, Alex</h1>
<p class="text-slate-500 text-xs">Ready to fix your home?</p>
</div>
</div>
<nav class="flex flex-col gap-1">
<a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary text-white" href="#">
<span class="material-symbols-outlined text-xl">home</span>
<span class="text-sm font-medium">Dashboard</span>
</a>
<a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800" href="#">
<span class="material-symbols-outlined text-xl">calendar_today</span>
<span class="text-sm font-medium">Bookings</span>
</a>
<a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800" href="#">
<span class="material-symbols-outlined text-xl">chat_bubble</span>
<span class="text-sm font-medium">Inbox</span>
</a>
<a class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800" href="#">
<span class="material-symbols-outlined text-xl">help_outline</span>
<span class="text-sm font-medium">Support</span>
</a>
</nav>
</div>
<!-- Progress Tracker -->
<div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
<div class="flex justify-between items-center mb-2">
<p class="text-slate-900 dark:text-white text-xs font-bold uppercase tracking-wider">Step 1 of 4</p>
<p class="text-primary text-xs font-bold">25%</p>
</div>
<div class="w-full h-2 bg-slate-100 dark:bg-slate-800 rounded-full mb-3">
<div class="h-full bg-primary rounded-full transition-all duration-500" style="width: 25%;"></div>
</div>
<p class="text-slate-500 text-xs font-medium">Ready to start your project?</p>
</div>
</aside>
<!-- Content Area -->
<div class="flex-1">
<div class="mb-8">
<h2 class="text-slate-900 dark:text-white text-3xl font-black leading-tight tracking-tight mb-2">How can we help you?</h2>
<p class="text-slate-500 text-base leading-relaxed">Select a category to find the right professional for your home project or repair.</p>
</div>
<!-- Service Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
<!-- Plumbing -->
