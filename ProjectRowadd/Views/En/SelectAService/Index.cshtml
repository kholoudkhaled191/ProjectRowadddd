<h3 class="text-slate-900 dark:text-white font-bold">Painters</h3>
</div>
<p class="text-slate-500 text-sm">Wall painting, wallpaper, and interior finishes</p>
</button>
<!-- HVAC -->
<button class="group flex flex-col items-start p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-primary hover:ring-1 hover:ring-primary transition-all text-left">
<div class="w-full h-40 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden mb-4 bg-center bg-cover" data-alt="Air conditioning unit maintenance by a technician" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAyaU6M1dAD40pGwW_HDWjNntO_o_3JiA1rrZjhzmlCNCJ9y8Tbmri2rrU6kQkdDkyzCkPW7CMYp2tGaCXW34n7llSScSQKfShQgZKtACddW77yD03XaPrFYZMN3oAWEXxZggp8b7lcTdUxmXoaveuNVOCRQwLoeCp6dcv-llQCPyAcwNIifrP2E2WJk2kDzlBbrMPc4MHV67fxQBlstZeafXZlE5eSfCEHnWd1CfQPOOx8PjpcyAb7Tax4jaOqTB6y8umADAUWUFk');"></div>
