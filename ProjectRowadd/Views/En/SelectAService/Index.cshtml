</button>
</div>
<!-- Footer Action -->
<div class="mt-12 flex justify-between items-center py-6 border-t border-slate-200 dark:border-slate-800">
<button class="px-6 py-2 text-slate-600 dark:text-slate-400 font-medium text-sm flex items-center gap-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg transition-colors"><span class="material-symbols-outlined">arrow_back</span> Back to Home</button>
<button class="px-8 py-3 bg-primary text-white font-bold rounded-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">Next Step <span class="material-symbols-outlined">arrow_forward</span></button>
