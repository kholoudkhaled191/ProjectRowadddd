<button class="group flex flex-col items-start p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:border-primary hover:ring-1 hover:ring-primary transition-all text-left">
<div class="w-full h-40 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden mb-4 bg-center bg-cover" data-alt="Carpenter measuring wood in a bright workshop" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAoF5Ogsz2EQfIH9vLV-EmnXtN7UBlbodm9wsTVydO3CBCnpi02q2noUo-B2eQZJNxTjjCmobYSRr8HhPOZVGjyb0GDP9NiNC4wzGz_hEt_tTYzZosEE_GuPwzxY5eILN0oe0W_0Z3VDMCFU09PMcx1EiyyZkE6Zzbj5Tpm3kFscApl9XOMIY-9muXaPgEg0UaXGljMTPpVZ3kC1SJzZ5KNLLGjQbQRkJdXvU8Z99-OWzoQ21pPf5joUkplT8Zephrc4I8D_wv1aTM');"></div>
