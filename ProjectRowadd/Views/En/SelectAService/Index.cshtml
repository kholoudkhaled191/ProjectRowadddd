<div class="w-full h-40 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden mb-4 bg-center bg-cover" data-alt="Clean living room after professional cleaning service" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCsh5AufTYIj9XfyFz7ON9X8qfYL1AypDAaOsCZQCFIi-0nyB9EG3YmucRvo_62A-HTeX7qF_FeKSI8w_O85FFf2aNkvLE52CTHEaLbSg5s575JFOuLgAKyATPrhWDuk8Jvzm6FqNN12-s5rOPmMRz-Dd2vQYyeQ3-r-iATfy8QsiuKZrjX-3IJYYk_U39qP-fPfA56QNDniolDnH0XWSA8y4R_XnK2KsvEeEJmLVpclce5j02-3bNDbnGEqlJcw8Vc3xP0IIyCcxU');"></div>
