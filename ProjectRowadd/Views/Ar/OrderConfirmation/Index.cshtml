@{
    ViewData["Title"] = "تأكيد الطلب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: rtl; font-family: 'Cairo', sans-serif; }

body {
            font-family: 'Noto Sans Arabic', 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
</style>

<div dir="rtl">
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<!-- Main Container -->
<div class="layout-container flex h-full grow flex-col">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between border-b border-primary/10 bg-white dark:bg-background-dark px-6 md:px-40 py-4 sticky top-0 z-50">
<div class="flex items-center gap-3">
<div class="flex items-center justify-center w-10 h-10 rounded-lg bg-primary text-white">
<span class="material-symbols-outlined text-2xl">handyman</span>
</div>
<h2 class="text-xl font-bold tracking-tight text-primary">صلاحلي</h2>
</div>
<div class="flex items-center gap-4">
<button class="flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
<span class="material-symbols-outlined">notifications</span>
</button>
<button class="flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300">
<span class="material-symbols-outlined">person</span>
</button>
</div>
</header>
<main class="flex-1 flex flex-col items-center py-8 px-4 md:px-0">
<div class="w-full max-w-[640px] flex flex-col gap-8">
<!-- Progress Indicator -->
<div class="flex flex-col gap-4 bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800">
<div class="flex justify-between items-center">
<p class="text-slate-900 dark:text-slate-100 font-bold">الخطوة 4 من 4</p>
<span class="text-primary font-bold text-sm bg-primary/10 px-2 py-1 rounded">100% مكتمل</span>
</div>
<div class="w-full h-3 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full w-full"></div>
</div>
<p class="text-slate-500 dark:text-slate-400 text-sm flex items-center gap-2">
<span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
                        تم إنهاء جميع خطوات الطلب بنجاح
                    </p>
</div>
<!-- Success Hero Section -->
<div class="flex flex-col items-center text-center py-6">
<div class="size-24 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-6">
<span class="material-symbols-outlined text-5xl" style="font-variation-settings: 'wght' 700">check_circle</span>
</div>
<h1 class="text-3xl font-extrabold text-slate-900 dark:text-slate-100 mb-3">تم تأكيد طلبك</h1>
<p class="text-slate-600 dark:text-slate-400 max-w-md mx-auto leading-relaxed">
                        شكراً لاستخدامك صلاحلي. تم استلام طلبك رقم <span class="font-bold text-primary">#SH-49201</span> وهو قيد التنفيذ الآن. سيتواصل معك الفني قريباً.
                    </p>
<div class="mt-8 w-full max-w-sm aspect-video rounded-xl overflow-hidden bg-slate-200 dark:bg-slate-800 relative group">
<img alt="Technician working" class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-500" data-alt="A professional technician repairing an electrical appliance" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_fgkhKaDudgX5ZMgkhGVGy7k7vJUcY-hKCojRkKCwH8VoxNIPbdq35LnZye_s_X3r21QvwWfg4j6ucRLbmhqPvnVhXXpi1tWvNuIB4er9fELkpoM5Wu47_ckLv5mi7mPyAiRSpWoPJkdpfepjHKlRkbIpXh_1kBA-1GNAPqCHbHdFGwfAzJCPFrxsRhJvN2Tmi5pGBsB_rb5jEs6ii-YbC78SwGxyH3oMcw6EpC_LCWPpsl_2kGHbxeM1oMfm-SPS5xI8e6iEkj0"/>
<div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"></div>
</div>
</div>
<!-- Order Summary -->
<div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-100 dark:border-slate-800 overflow-hidden">
<div class="p-5 border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">receipt_long</span>
<h2 class="text-lg font-bold">ملخص الطلب</h2>
</div>
<div class="p-6 flex flex-col gap-4">
<div class="flex justify-between items-center">
<span class="text-slate-500 dark:text-slate-400">الخدمة المطلوبة:</span>
<span class="font-semibold">صيانة تكييف مركزي</span>
</div>
<div class="flex justify-between items-center">
<span class="text-slate-500 dark:text-slate-400">تاريخ الموعد:</span>
<span class="font-semibold">الأربعاء، 24 أكتوبر - 10:00 صباحاً</span>
</div>
<div class="flex justify-between items-center">
<span class="text-slate-500 dark:text-slate-400">الموقع:</span>
<span class="font-semibold text-left" dir="ltr">Riyadh, Al-Olaya St.</span>
</div>
<hr class="border-slate-100 dark:border-slate-800"/>
<div class="flex justify-between items-center pt-2">
<span class="text-lg font-bold">إجمالي المبلغ التقريبي:</span>
<span class="text-xl font-bold text-primary">150 ر.س</span>
</div>
</div>
</div>
<!-- Map Location (Placeholder) -->
<div class="rounded-xl overflow-hidden h-48 bg-slate-200 dark:bg-slate-800 relative">
<img alt="Map" class="w-full h-full object-cover" data-alt="Map showing the service location in Riyadh city" data-location="Riyadh" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAG_1cs1FGwyrK_dS06OLJieX-f9WQ4Rdf5nTjEazdc9I9oP-ygQgO9WtmGCnc-vlQlKIdOFX2VoAn45CcCIK9TpokfEuZHgqZ7HuiQdF9MyMpMdDzjcW62_38oNZGaTtew0J9H_Tw3YcPb7NtQyKSbrDrajlidXcAJdEl0Qb1yOehXIAvTk1l7mH-avqdSQFLVnNPF1O9uJwfleC12KgjquEWl5l2j6d-hwI22PXuIPLkLpOHjxGELDt9APBvyJ0TU2kIJR-G1eNI"/>
<div class="absolute inset-0 flex items-center justify-center">
<div class="bg-primary text-white p-2 rounded-full shadow-lg">
<span class="material-symbols-outlined text-3xl">location_on</span>
</div>
</div>
</div>
<!-- Action Buttons -->
<div class="flex flex-col sm:flex-row gap-4 pt-4">
<button class="flex-1 bg-primary text-white h-14 rounded-xl font-bold text-lg hover:bg-primary/90 transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
<span class="material-symbols-outlined">dashboard</span>
                        العودة للرئيسية
                    </button>
<button class="flex-1 bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 h-14 rounded-xl font-bold text-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-all flex items-center justify-center gap-2">
<span class="material-symbols-outlined">visibility</span>
                        تفاصيل الطلب
                    </button>
</div>
<!-- Support Footer -->
<div class="text-center py-10">
<p class="text-slate-500 dark:text-slate-400 mb-2">هل لديك أي استفسار؟</p>
<a class="text-primary font-bold flex items-center justify-center gap-1 hover:underline" href="#">
<span class="material-symbols-outlined text-sm">support_agent</span>
                        تواصل مع الدعم الفني
                    </a>
</div>
</div>
</main>
<!-- Bottom Tab Bar (Mobile) -->
<footer class="md:hidden sticky bottom-0 bg-white dark:bg-background-dark border-t border-slate-100 dark:border-slate-800 px-6 py-3 flex justify-around items-center">
<div class="flex flex-col items-center gap-1 text-primary">
<span class="material-symbols-outlined">home</span>
<span class="text-[10px] font-bold">الرئيسية</span>
</div>
<div class="flex flex-col items-center gap-1 text-slate-400">
<span class="material-symbols-outlined">history</span>
<span class="text-[10px]">طلباتي</span>
</div>
<div class="flex flex-col items-center gap-1 text-slate-400">
<span class="material-symbols-outlined">wallet</span>
<span class="text-[10px]">المحفظة</span>
</div>
<div class="flex flex-col items-center gap-1 text-slate-400">
<span class="material-symbols-outlined">settings</span>
<span class="text-[10px]">الاعدادات</span>
</div>
</footer>
</div>
</div>
</div>
