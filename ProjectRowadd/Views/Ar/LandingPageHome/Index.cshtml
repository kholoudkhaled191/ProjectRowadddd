<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-12">
<div class="col-span-2">
<div class="flex items-center gap-2 text-primary mb-6">
<div class="size-6 flex items-center justify-center bg-primary rounded-md text-white">
