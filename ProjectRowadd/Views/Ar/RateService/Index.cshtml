@{
    ViewData["Title"] = "تقييم الخدمة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: rtl; font-family: 'Cairo', sans-serif; }

body { font-family: 'Noto Sans Arabic', sans-serif; }
</style>

<div dir="rtl">
<div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Navigation Bar -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-4 md:px-10 py-3 sticky top-0 z-50">
<div class="flex items-center gap-4">
<div class="text-primary">
<span class="material-symbols-outlined text-3xl">build_circle</span>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-lg font-bold leading-tight tracking-[-0.015em]">صلاحلي</h2>
</div>
<div class="flex gap-2">
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200">
<span class="material-symbols-outlined">notifications</span>
</button>
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200">
<span class="material-symbols-outlined">close</span>
</button>
</div>
</header>
<main class="flex flex-1 justify-center py-8 px-4">
<div class="layout-content-container flex flex-col max-w-[560px] flex-1 bg-white dark:bg-slate-900 rounded-xl shadow-sm p-6 md:p-10 border border-slate-100 dark:border-slate-800">
<!-- Header Section -->
<div class="text-center mb-8">
<h1 class="text-slate-900 dark:text-slate-100 text-2xl md:text-3xl font-bold mb-2">تقييم الخدمة</h1>
<p class="text-slate-500 dark:text-slate-400 text-sm">شكراً لاستخدامك صلاحلي، نأمل أن تكون راضياً عن الخدمة</p>
</div>
<!-- Professional Profile Card -->
<div class="flex flex-col items-center gap-4 mb-10 p-6 bg-primary/5 dark:bg-primary/10 rounded-xl border border-primary/10">
<div class="relative">
<div class="size-24 rounded-full border-4 border-white dark:border-slate-800 shadow-md bg-center bg-no-repeat bg-cover" data-alt="صورة شخصية لفني صيانة محترف يبتسم" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAvTZWb_ZuUURSQ_FpSh8unkV1RN5D6bbhb6JPDKgG_QKRyMqVGOsM6VBcZJrT4a3bOwNycYaHNetDd-BBoV1J9lkOoLsbJG11hkf7HwG1cHjIIa3m5251dkbOyb9mTwOfKDVf3Y1iJtqkc9rGSSjtSf-aHXnEPa8WFJt5MZMiMz0Y2D0grnzl9ar9D7xZuNzTUDF-KVFfL_w9i1aGWo2kjZCFBdFUeq19JCgK8PS5DFsBNJFGZK2QWhiMchcQBBZIyhI9z3Ng1_08");'>
</div>
<div class="absolute bottom-1 right-1 bg-green-500 size-4 rounded-full border-2 border-white dark:border-slate-800"></div>
</div>
<div class="text-center">
<p class="text-slate-900 dark:text-slate-100 text-xl font-bold">أحمد محمد</p>
<p class="text-primary font-medium text-sm">فني سباكة وكهرباء معتمد</p>
</div>
</div>
<!-- Rating Stars -->
<div class="flex flex-col items-center gap-4 mb-8">
<h3 class="text-slate-900 dark:text-slate-100 text-lg font-bold">كيف كانت جودة العمل؟</h3>
<div class="flex gap-2 text-amber-400">
<button class="p-1 hover:scale-110 transition-transform"><span class="material-symbols-outlined !text-4xl fill-current">star</span></button>
<button class="p-1 hover:scale-110 transition-transform"><span class="material-symbols-outlined !text-4xl fill-current">star</span></button>
<button class="p-1 hover:scale-110 transition-transform"><span class="material-symbols-outlined !text-4xl fill-current">star</span></button>
<button class="p-1 hover:scale-110 transition-transform"><span class="material-symbols-outlined !text-4xl fill-current">star</span></button>
<button class="p-1 hover:scale-110 transition-transform text-slate-300 dark:text-slate-700"><span class="material-symbols-outlined !text-4xl">star</span></button>
</div>
<p class="text-slate-500 text-sm">جيد جداً</p>
</div>
<!-- Quick Tags -->
<div class="mb-8">
<h3 class="text-slate-900 dark:text-slate-100 text-base font-bold mb-4">ما أكثر ما أعجبك؟</h3>
<div class="flex flex-wrap gap-2">
<button class="px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 text-sm font-medium hover:bg-primary/10 hover:border-primary transition-colors">الدقة في الموعد</button>
<button class="px-4 py-2 rounded-full bg-primary text-white text-sm font-medium">نظافة العمل</button>
<button class="px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 text-sm font-medium hover:bg-primary/10 hover:border-primary transition-colors">الأدوات المستخدمة</button>
<button class="px-4 py-2 rounded-full border border-slate-200 dark:border-slate-700 text-sm font-medium hover:bg-primary/10 hover:border-primary transition-colors">السعر مناسب</button>
</div>
</div>
<!-- Review Textarea -->
<div class="flex flex-col gap-2 mb-8">
<label class="text-slate-900 dark:text-slate-100 text-base font-bold">أضف تعليقك (اختياري)</label>
<textarea class="w-full min-h-[120px] rounded-xl border border-slate-200 dark:border-slate-700 bg-background-light dark:bg-slate-800 p-4 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none placeholder:text-slate-400 dark:placeholder:text-slate-500" placeholder="اكتب تجربتك هنا بالتفصيل..."></textarea>
</div>
<!-- Photo Upload Placeholder -->
<div class="mb-10">
<button class="w-full border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-xl py-6 flex flex-col items-center gap-2 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
<span class="material-symbols-outlined text-3xl">add_a_photo</span>
<span class="text-sm font-medium">أضف صوراً للعمل المنجز</span>
</button>
</div>
<!-- Action Buttons -->
<div class="flex flex-col gap-3">
<button class="w-full bg-primary text-white h-14 rounded-xl font-bold text-lg shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all">إرسال التقييم</button>
<button class="w-full bg-transparent text-slate-500 dark:text-slate-400 h-12 rounded-xl font-medium text-base hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">تخطي الآن</button>
</div>
<!-- Safety Note -->
<div class="mt-8 pt-8 border-t border-slate-100 dark:border-slate-800 flex items-center gap-3 text-slate-400">
<span class="material-symbols-outlined text-xl">verified_user</span>
<p class="text-xs">يتم مراجعة جميع التقييمات لضمان جودة الخدمة في منصة صلاحلي.</p>
</div>
</div>
</main>
</div>
</div>
</div>
