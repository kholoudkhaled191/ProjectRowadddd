@{
    ViewData["Title"] = "تتبع حالة الطلب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: rtl; font-family: 'Cairo', sans-serif; }

body {
            font-family: 'Noto Sans Arabic', 'Inter', sans-serif;
        }
        .step-active {
            color: #0f2cbd;
        }
        .step-line-active {
            background-color: #0f2cbd;
        }
</style>

<div dir="rtl">
<div class="relative flex h-auto min-h-screen w-full flex-col bg-background-light dark:bg-background-dark group/design-root overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-background-dark px-6 md:px-20 py-4 sticky top-0 z-50">
<div class="flex items-center gap-4">
<div class="size-8 bg-primary rounded-lg flex items-center justify-center text-white">
<span class="material-symbols-outlined">build</span>
</div>
<h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-tight">تتبع الطلب</h2>
</div>
<div class="flex gap-3">
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
<span class="material-symbols-outlined">notifications</span>
</button>
<button class="flex items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 md:hidden">
<span class="material-symbols-outlined">menu</span>
</button>
</div>
</header>
<main class="flex-1 flex justify-center py-6 px-4 md:px-20">
<div class="layout-content-container flex flex-col max-w-[960px] flex-1 gap-6">
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
<div>
<h1 class="text-2xl font-bold text-slate-900 dark:text-slate-100">طلب رقم #82734</h1>
<p class="text-slate-500 dark:text-slate-400 mt-1">تم إنشاء الطلب: اليوم، 10:30 صباحاً</p>
</div>
<span class="px-4 py-2 bg-primary/10 text-primary font-bold rounded-full text-sm">
                                الفني في الطريق
                            </span>
</div>
<div class="relative">
<div class="grid grid-cols-[48px_1fr] gap-x-4">
<div class="flex flex-col items-center">
<div class="flex items-center justify-center size-10 rounded-full bg-primary text-white">
<span class="material-symbols-outlined text-[20px]">check</span>
</div>
<div class="w-1 bg-primary h-12"></div>
</div>
<div class="pb-8">
<p class="text-slate-900 dark:text-slate-100 font-bold">قيد المراجعة</p>
<p class="text-slate-500 dark:text-slate-400 text-sm">تم استلام طلبك وبانتظار تأكيد النظام</p>
<p class="text-xs text-slate-400 mt-1">10:32 ص</p>
</div>
<div class="flex flex-col items-center">
<div class="flex items-center justify-center size-10 rounded-full bg-primary text-white">
<span class="material-symbols-outlined text-[20px]">thumb_up</span>
</div>
<div class="w-1 bg-primary h-12"></div>
</div>
<div class="pb-8">
<p class="text-slate-900 dark:text-slate-100 font-bold">تم القبول</p>
<p class="text-slate-500 dark:text-slate-400 text-sm">تمت الموافقة على طلب الصيانة وتخصيص الفني</p>
<p class="text-xs text-slate-400 mt-1">10:45 ص</p>
</div>
<div class="flex flex-col items-center">
<div class="flex items-center justify-center size-10 rounded-full bg-primary text-white ring-4 ring-primary/20">
<span class="material-symbols-outlined text-[20px]">local_shipping</span>
</div>
<div class="w-1 bg-slate-200 dark:bg-slate-700 h-12"></div>
</div>
<div class="pb-8">
<p class="text-primary font-bold">الفني في الطريق</p>
<p class="text-slate-500 dark:text-slate-400 text-sm">يتحرك الفني الآن باتجاه موقعك</p>
<p class="text-primary text-xs font-medium mt-1">الوقت المتوقع للوصول: 15 دقيقة</p>
</div>
<div class="flex flex-col items-center">
<div class="flex items-center justify-center size-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400">
<span class="material-symbols-outlined text-[20px]">handyman</span>
</div>
<div class="w-1 bg-slate-200 dark:bg-slate-700 h-12"></div>
</div>
<div class="pb-8">
<p class="text-slate-400 dark:text-slate-600 font-bold">قيد العمل</p>
<p class="text-slate-400 dark:text-slate-600 text-sm">العمل جارٍ على إصلاح العطل</p>
</div>
<div class="flex flex-col items-center">
<div class="flex items-center justify-center size-10 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400">
<span class="material-symbols-outlined text-[20px]">verified</span>
</div>
</div>
<div>
<p class="text-slate-400 dark:text-slate-600 font-bold">مكتمل</p>
<p class="text-slate-400 dark:text-slate-600 text-sm">تم إنجاز المهمة بنجاح</p>
</div>
</div>
</div>
</div>
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
<h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-6">تفاصيل الفني</h3>
<div class="flex items-center justify-between">
<div class="flex items-center gap-4">
<img alt="صورة الفني" class="size-16 rounded-full object-cover ring-2 ring-primary/10" data-alt="فني صيانة محترف يرتدي زيا أزرق" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA7gFFQZjZ6hN41_bTYrbhLzhIILrZo6JZM2Op2t9iG0MHS8HpKCj6nwdOQU65s67oG-iIsG0hWBQBeUWyKEpCCwbVG8BthVfqmpu7hYG5v5p8ceCbwePhR9eNdxqdcaJtvaqqYwOLyRMxv8RIvZwQ12r24hvHbnqWqQoJAhtch90ae0i-WhgNX-BhgJxc98F09J8m9cGpNvtaj5TemVTWewyrsSeY2cFipJRSh0JhJ0UhrCInKHSt3beFWZQ5zQpJGDJ7p-1U6hi8"/>
<div>
<h4 class="font-bold text-slate-900 dark:text-slate-100">أحمد محمود</h4>
<p class="text-slate-500 dark:text-slate-400 text-sm">خبير كهرباء - تقييم 4.9 ★</p>
</div>
</div>
<div class="flex gap-2">
<button class="flex items-center justify-center size-12 rounded-full bg-primary text-white shadow-lg shadow-primary/20 hover:bg-primary/90">
<span class="material-symbols-outlined">call</span>
</button>
<button class="flex items-center justify-center size-12 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
<span class="material-symbols-outlined">chat</span>
</button>
</div>
</div>
</div>
<div class="bg-white dark:bg-slate-900 rounded-xl p-6 shadow-sm border border-slate-100 dark:border-slate-800">
<h3 class="text-lg font-bold text-slate-900 dark:text-slate-100 mb-4">موقع الفني المباشر</h3>
<div class="h-64 bg-slate-100 dark:bg-slate-800 rounded-lg overflow-hidden relative">
<img alt="خريطة الموقع" class="w-full h-full object-cover" data-alt="خريطة مدينة مع أيقونة موقع فني" data-location="Cairo" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCrI-3bi_wllK9qzfwfDR3kOwIKHdAzKvwZzkoshmdPzCvj_0qPYixcLH0pSiYggC308GkojyOUak8vXz7En7Mh6H_jOK2F4U2LKYHNnJNjEDFRsH2t89ItUY662LhOhOP6X0dwBeS1_zqQvlBUFIbznihqEFYr23NUZ0_KSEcqqA6daW5tu_UTebH4cE_QaJBUo4lptqKWjmIjm-jGgsKE7ib13nce4-JiH3UHd3qPWcFlIhsaoNoNCi5Z3EHPTaSJoVg9oP31XK4"/>
<div class="absolute inset-0 flex items-center justify-center">
<div class="bg-primary/20 p-8 rounded-full animate-pulse">
<div class="bg-primary p-2 rounded-full shadow-lg">
<span class="material-symbols-outlined text-white">navigation</span>
</div>
</div>
</div>
</div>
<div class="mt-4 flex items-start gap-3 bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg">
<span class="material-symbols-outlined text-primary">location_on</span>
<p class="text-sm text-slate-600 dark:text-slate-400">
                                العنوان الحالي: حي الياسمين، شارع التخصصي، الرياض، المملكة العربية السعودية
                            </p>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<button class="w-full py-4 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
<span class="material-symbols-outlined">support_agent</span>
                            تواصل مع الدعم الفني
                        </button>
<button class="w-full py-4 border-2 border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 font-bold rounded-xl flex items-center justify-center gap-2">
<span class="material-symbols-outlined">cancel</span>
                            إلغاء الطلب
                        </button>
</div>
</div>
</main>
<footer class="bg-white dark:bg-background-dark border-t border-slate-200 dark:border-slate-800 py-6 text-center">
<p class="text-slate-500 dark:text-slate-400 text-sm">جميع الحقوق محفوظة لمنصة صلاحلي © 2024</p>
</footer>
</div>
</div>
</div>
