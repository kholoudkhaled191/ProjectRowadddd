@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: rtl; font-family: 'Cairo', sans-serif; }

body {
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
</style>

<div dir="rtl">
<div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
<div class="layout-container flex h-full grow flex-col">
<!-- Header/Top Nav -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 px-6 md:px-10 py-4 bg-white dark:bg-slate-900">
<div class="flex items-center gap-3">
<div class="flex items-center justify-center bg-primary rounded-lg p-1.5 text-white">
<span class="material-symbols-outlined text-2xl">verified_user</span>
</div>
<h2 class="text-slate-900 dark:text-white text-xl font-bold leading-tight tracking-tight">Salahly</h2>
</div>
<div class="flex items-center gap-2">
<span class="text-sm text-slate-500 dark:text-slate-400 hidden sm:inline">اتصال آمن</span>
<span class="material-symbols-outlined text-primary">shield</span>
</div>
</header>
<main class="flex-1 flex items-center justify-center p-6">
<div class="w-full max-w-[480px] space-y-8">
<!-- Welcome Text -->
<div class="text-center md:text-right">
<h1 class="text-slate-900 dark:text-white text-4xl font-black leading-tight tracking-tight mb-2">مرحباً بعودتك</h1>
<p class="text-slate-500 dark:text-slate-400 text-base font-normal">يرجى إدخال بياناتك للوصول إلى حسابك المؤمن.</p>
</div>
<!-- Login Form Card -->
<div class="bg-white dark:bg-slate-900 p-8 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
<form class="space-y-6" onsubmit="return false;">
<!-- Username/Email -->
<div class="space-y-2">
<label class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal" for="email">اسم المستخدم أو البريد الإلكتروني</label>
<div class="relative flex items-center">
<span class="material-symbols-outlined absolute text-slate-400 right-3">mail</span>
<input class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pr-11 pl-4" id="email" placeholder="name@company.com" type="text"/>
</div>
</div>
<!-- Password -->
<div class="space-y-2">
<label class="text-slate-900 dark:text-slate-200 text-sm font-semibold leading-normal" for="password">كلمة المرور</label>
<div class="relative flex items-center">
<span class="material-symbols-outlined absolute text-slate-400 right-3">lock</span>
<input class="form-input flex w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white h-12 focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:text-slate-400 pr-11 pl-12" id="password" placeholder="••••••••" type="password"/>
<button class="absolute text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 left-3" type="button">
<span class="material-symbols-outlined">visibility</span>
</button>
</div>
</div>
<!-- Remember Me & Forgot Password -->
<div class="flex items-center justify-between">
<label class="flex items-center gap-2 cursor-pointer">
<input class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary dark:bg-slate-800 dark:border-slate-700" type="checkbox"/>
<span class="text-sm text-slate-600 dark:text-slate-400 font-medium">تذكرني</span>
</label>
<a class="text-sm font-semibold text-primary hover:underline underline-offset-4" href="#">نسيت كلمة المرور؟</a>
</div>
<!-- Login Button -->
<button class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg transition-colors flex items-center justify-center gap-2 shadow-lg shadow-primary/20">
<span>تسجيل الدخول</span>
<span class="material-symbols-outlined text-[20px]">login</span>
</button>
</form>
<!-- Divider -->
<div class="relative my-8">
<div class="absolute inset-0 flex items-center">
<span class="w-full border-t border-slate-200 dark:border-slate-800"></span>
</div>
<div class="relative flex justify-center text-xs uppercase">
<span class="bg-white dark:bg-slate-900 px-2 text-slate-500 dark:text-slate-400 font-medium tracking-wider">وصول آمن</span>
</div>
</div>
<!-- SSO/Alternative Option (Social) -->
<div class="grid grid-cols-1 gap-3">
<button class="flex items-center justify-center h-12 w-full rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 text-sm font-semibold hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors gap-3"><svg class="w-5 h-5" viewbox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg> المتابعة باستخدام جوجل</button>
</div>
</div>
<!-- Registration Link -->
<p class="text-center text-slate-500 dark:text-slate-400 text-sm">ليس لديك حساب؟ <a class="font-bold text-primary hover:underline underline-offset-4" href="#">إنشاء حساب جديد</a></p>
</div>
</main>
<!-- Footer -->
<footer class="p-6 text-center text-slate-400 dark:text-slate-500 text-xs">
<div class="flex justify-center gap-6 mb-4">
<a class="hover:text-slate-600 dark:hover:text-slate-300" href="#">سياسة الخصوصية</a>
<a class="hover:text-slate-600 dark:hover:text-slate-300" href="#">شروط الخدمة</a>
<a class="hover:text-slate-600 dark:hover:text-slate-300" href="#">مركز المساعدة</a>
</div>
<p>© 2024 Salahly. جميع الحقوق محفوظة. مؤمن بتشفير المؤسسات.</p>
</footer>
</div>
</div>
</div>
