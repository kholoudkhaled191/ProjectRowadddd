@{
    ViewData["Title"] = "مركز الشكاوى";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body { direction: rtl; font-family: 'Cairo', sans-serif; }


</style>

<div dir="rtl">
<div class="relative flex min-h-screen w-full flex-col">
<!-- Top Navigation Bar -->
<header class="flex items-center justify-between whitespace-nowrap border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-6 py-3 lg:px-40">
<div class="flex items-center gap-4">
<div class="text-primary">
<span class="material-symbols-outlined text-3xl">handyman</span>
</div>
<h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight tracking-tight">Salahly</h2>
</div>
<div class="flex flex-1 justify-end gap-4 lg:gap-8 items-center">
<label class="hidden md:flex flex-col min-w-40 h-10 max-w-64">
<div class="flex w-full flex-1 items-stretch rounded-lg h-full">
<div class="text-slate-500 flex border-none bg-slate-100 dark:bg-slate-800 items-center justify-center pl-4 rounded-l-lg" data-icon="search">
<span class="material-symbols-outlined">search</span>
</div>
<input class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-slate-900 dark:text-white focus:outline-0 focus:ring-0 border-none bg-slate-100 dark:bg-slate-800 h-full placeholder:text-slate-500 px-4 rounded-l-none pl-2 text-base font-normal" placeholder="البحث عن الشكاوى..." value=""/>
</div>
</label>
<button class="flex cursor-pointer items-center justify-center rounded-lg h-10 w-10 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
<span class="material-symbols-outlined">notifications</span>
</button>
<div class="h-10 w-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">JD</div>
</div>
</header>
<main class="flex flex-col lg:flex-row flex-1 px-4 lg:px-40 py-8 gap-8">
<!-- Sidebar Navigation -->
<aside class="w-full lg:w-64 flex flex-col gap-6">
<div class="flex flex-col gap-1">
<h1 class="text-slate-900 dark:text-white text-lg font-bold">مركز الشكاوى</h1>
<p class="text-slate-500 text-sm">إدارة ومتابعة مشاكل الخدمة</p>
</div>
<nav class="flex flex-col gap-2">
<a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium" href="#">
<span class="material-symbols-outlined">dashboard</span>
<span>لوحة القيادة</span>
</a>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined">add_circle</span>
<span>تقديم شكوى</span>
</a>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined">history</span>
<span>تقاريري</span>
</a>
<div class="border-t border-slate-200 dark:border-slate-800 my-2"></div>
<a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" href="#">
<span class="material-symbols-outlined">settings</span>
<span>الإعدادات</span>
</a>
</nav>
</aside>
<!-- Main Content Area -->
<div class="flex-1 flex flex-col gap-8">
<!-- Section 1: Submit Complaint Form (FR-35) -->
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
<div class="flex items-center gap-2 mb-6">
<span class="material-symbols-outlined text-primary">edit_document</span>
<h2 class="text-xl font-bold text-slate-900 dark:text-white">تقديم شكوى جديدة</h2>
</div>
<form class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">رقم طلب الخدمة</label>
<input class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:border-primary focus:ring-primary w-full p-3" placeholder="مثال: #SR-98231" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">الموضوع</label>
<input class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:border-primary focus:ring-primary w-full p-3" placeholder="ملخص موجز للمشكلة" type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">الوصف</label>
<textarea class="rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800 focus:border-primary focus:ring-primary w-full p-3" placeholder="صف المشكلة بالتفصيل..." rows="4"></textarea>
</div>
<div class="flex flex-col gap-2 md:col-span-2">
<label class="text-sm font-semibold text-slate-700 dark:text-slate-300">المرفقات</label>
<div class="border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl p-8 flex flex-col items-center justify-center text-slate-500 hover:border-primary transition-colors cursor-pointer">
<span class="material-symbols-outlined text-4xl mb-2">cloud_upload</span>
<p class="text-sm">قم بسحب وإفلات الملفات هنا أو اضغط للتصفح</p>
<p class="text-xs mt-1">الحد الأقصى لحجم الملف 5 ميجابايت (JPG، PNG، PDF)</p>
</div>
</div>
<div class="md:col-span-2 flex justify-end gap-3 mt-2">
<button class="px-6 py-2.5 rounded-lg font-semibold text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" type="button">إلغاء</button>
<button class="px-8 py-2.5 rounded-lg font-semibold bg-primary text-white hover:bg-primary/90 transition-colors shadow-md" type="submit">إرسال الشكوى</button>
</div>
</form>
</section>
<!-- Section 2: Admin Dashboard View (FR-36, FR-37) -->
<section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
<div class="p-6 border-b border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
<div>
<h2 class="text-xl font-bold text-slate-900 dark:text-white">الشكاوى الأخيرة</h2>
<p class="text-slate-500 text-sm">عرض إدارة المسؤول</p>
</div>
<div class="flex gap-2 w-full md:w-auto">
<button class="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm font-medium border border-slate-200 dark:border-slate-700"><span class="material-symbols-outlined text-sm">filter_list</span>تصفية</button>
<button class="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm font-medium border border-slate-200 dark:border-slate-700"><span class="material-symbols-outlined text-sm">download</span>تصدير</button>
</div>
</div>
<div class="overflow-x-auto">
