<div class="flex gap-6">
<a class="text-sm text-slate-500 hover:text-primary transition-colors" href="#">سياسة الخصوصية</a>
<a class="text-sm text-slate-500 hover:text-primary transition-colors" href="#">شروط الخدمة</a>
<a class="text-sm text-slate-500 hover:text-primary transition-colors" href="#">الدعم</a>
</div>
</footer>
</div>
</div>
