<td class="p-4 text-sm text-slate-600 dark:text-slate-400 max-w-[200px] truncate">Delay in AC installation service</td>
<td class="p-4">
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">جديد</span>
</td>
<td class="p-4 text-right">
<div class="flex justify-end gap-2">
<button class="px-3 py-1.5 text-xs font-bold rounded bg-primary text-white hover:bg-primary/90">رد</button>
<button class="px-3 py-1.5 text-xs font-bold rounded bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 border border-slate-200 dark:border-slate-700">إجراء</button>
</div>
</td>
</tr>
<!-- Row 2: Under Review -->
<tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
